        ],
        [
          {
            "type": "text",
            "value": "可变字体 "
          },
          {
            "type": "code",
            "value": "font-variation-settings"
          },
          {
            "type": "text",
            "value": " 一文件多字重；注意版权与许可。"
          }
        ]
      ]
    },
    {
      "id": "q-preload",
      "navLabel": "preload 与 prefetch",
      "question": "link rel=preload 和 prefetch 区别？",
      "answer": [
        [
          {
            "type": "code",
            "value": "preload"
