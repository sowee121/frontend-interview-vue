    {
      "id": "q-resource-hints",
      "navLabel": "资源提示",
      "question": "dns-prefetch、preconnect、preload、prefetch 怎么选？",
      "answer": [
        [
          {
            "type": "code",
            "value": "dns-prefetch"
          },
          {
            "type": "text",
