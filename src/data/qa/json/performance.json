          {
            "type": "code",
            "value": "as"
          },
          {
            "type": "text",
            "value": " 要与真实请求类型一致，否则浪费带宽。"
          }
        ],
        [
          {
            "type": "code",
            "value": "prefetch"
          },
          {
            "type": "text",
            "value": "："
          },
          {
            "type": "strong",
            "value": "低优先级"
          },
          {
            "type": "text",
            "value": "在浏览器空闲时预取下一路由可能用到的资源，适合 SPA 下一页。"
          },
          {
            "type": "code",
            "value": "preconnect/dns-prefetch"
          },
          {
            "type": "text",
            "value": " 则提前建连/解析域名，减 TLS RTT。"
          }
        ]
      ]
    },
    {
