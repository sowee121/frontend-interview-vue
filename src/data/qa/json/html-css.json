      "answer": [
        [
          {
            "type": "code",
            "value": "@media (prefers-color-scheme: dark) { ... }"
          },
          {
            "type": "text",
            "value": " 写暗色变量覆盖，跟随系统偏好。"
          }
        ],
        [
          {
            "type": "text",
            "value": "根上用 "
          },
          {
            "type": "code",
            "value": ":root"
          },
          {
            "type": "text",
            "value": " 定义亮色变量，"
          },
          {
            "type": "code",
            "value": "html.dark"
          },
          {
            "type": "text",
            "value": " class 切换暗色；系统一套、用户手动一套，手动优先级更高。"
          }
        ],
        [
          {
            "type": "code",
            "value": "color-scheme: dark"
          },
          {
            "type": "text",
            "value": " 让原生表单滚动条与系统 UI 协调；图片/图标注意对比度，参考 Web 内容无障碍指南（WCAG）。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "跟随系统深色。"
          }
        ],
        [
          {
            "type": "code",
            "value": ":root { color-scheme: light dark; }\n@media (prefers-color-scheme: dark) {\n  :root { --bg: #111; --fg: #eee; }\n}\nbody { background: var(--bg); color: var(--fg); }"
          }
        ]
      ]
    },
