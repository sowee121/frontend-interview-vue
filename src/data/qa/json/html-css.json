          }
        ],
        [
          {
            "type": "text",
            "value": "1）"
          },
          {
            "type": "strong",
            "value": "伪元素 + transform 缩放"
          },
          {
            "type": "text",
            "value": "："
          },
          {
            "type": "code",
            "value": "::after"
          },
          {
            "type": "text",
            "value": " 画 1px 高，"
          },
          {
