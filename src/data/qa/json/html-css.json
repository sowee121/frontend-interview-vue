        ],
        [
          {
            "type": "text",
            "value": "二维对齐："
          },
          {
            "type": "code",
            "value": "display: grid; place-items: center;"
          },
          {
            "type": "text",
            "value": "，行列同时居中。"
          }
        ],
        [
          {
            "type": "text",
            "value": "传统方案：绝对定位配合 "
          },
          {
            "type": "code",
            "value": "top:50%; left:50%; transform: translate(-50%,-50%)"
          },
          {
            "type": "text",
            "value": "；兼容旧代码时可补充说明。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "水平垂直居中。"
          }
        ],
        [
          {
            "type": "code",
            "value": ".box {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}"
          }
