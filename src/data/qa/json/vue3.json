          { "type": "code", "value": "readonly(x)" },
          { "type": "text", "value": "：创建只读视图，防止下游误改；" },
          { "type": "code", "value": "shallowReactive" },
          { "type": "text", "value": " 只代理第一层，性能优化前提是先定位瓶颈再用 shallow。" }
