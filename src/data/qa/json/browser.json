          },
          {
            "type": "text",
            "value": "（占带宽），可设 "
          },
          {
            "type": "code",
            "value": "Expires / Max-Age"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "HttpOnly"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "SameSite"
          },
          {
            "type": "text",
            "value": "，适合会话标识或与后端约定的轻量标记。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "localStorage"
          },
          {
            "type": "text",
            "value": "：同源约 5～10MB（浏览器实现不同）、"
          },
          {
            "type": "strong",
            "value": "不参与请求"
          },
          {
            "type": "text",
            "value": "、关浏览器仍在，适合主题、草稿、离线配置；"
          },
          {
            "type": "strong",
            "value": "sessionStorage"
          },
          {
            "type": "text",
            "value": "：生命周期跟"
          },
          {
            "type": "strong",
            "value": "标签页"
          },
          {
            "type": "text",
            "value": "走，关页清空，适合多步表单防刷新丢数据。"
          }
        ]
      ]
    },
    {
      "id": "q-cookie-samesite",
      "navLabel": "SameSite 详解",
      "question": "Cookie 的 SameSite=Lax 和 Strict 区别？",
