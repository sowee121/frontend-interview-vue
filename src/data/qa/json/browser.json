          {
            "type": "code",
            "value": "install -> waiting -> activate"
          },
          {
            "type": "text",
            "value": "，更新策略要设计好避免用户永远拿到旧壳。"
          }
        ],
        [
          {
            "type": "text",
            "value": "必须 "
          },
          {
            "type": "code",
            "value": "HTTPS"
          },
          {
            "type": "text",
            "value": "（localhost 例外）；"
          },
          {
            "type": "code",
            "value": "navigator.serviceWorker.register"
