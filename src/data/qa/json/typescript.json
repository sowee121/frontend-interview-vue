          },
          {
            "type": "text",
            "value": "，需要补上类型注解。可按目录逐步开 "
          },
          {
            "type": "code",
            "value": "strict"
          },
          {
            "type": "text",
            "value": "，不必一次全仓改完。"
          }
        ]
      ]
    },
