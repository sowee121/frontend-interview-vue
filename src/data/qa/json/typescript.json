  "items": [
    {
      "id": "q-why",
      "navLabel": "为何采用 TS",
      "question": "请说明项目采用 TypeScript 的主要动机。",
      "questionNote": "突出编译期类型检查与编辑器智能提示两大核心收益。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "TypeScript 是 JavaScript 的超集，在编译阶段进行类型检查；字段变更时可一次性定位引用，编辑器补全与跳转也更准确。"
          }
        ],
        [
          {
            "type": "text",
            "value": "1）"
          },
          {
            "type": "strong",
            "value": "编译期发现错误"
          },
          {
            "type": "text",
            "value": "：接口字段从 "
          },
          {
            "type": "code",
            "value": "name"
          },
          {
            "type": "text",
            "value": " 改为 "
          },
          {
            "type": "code",
            "value": "username"
          },
          {
            "type": "text",
            "value": " 后，类型变更会使引用处编译报错，优于运行时才暴露问题。"
          }
        ],
        [
          {
            "type": "text",
            "value": "2）"
          },
          {
            "type": "strong",
            "value": "工程代价"
          },
          {
            "type": "text",
            "value": "：需编写类型声明；部分第三方库缺少类型时需补充 "
          },
          {
            "type": "code",
            "value": ".d.ts"
          },
          {
            "type": "text",
            "value": "。整体收益通常大于成本。"
          }
        ]
      ]
    },
    {
      "id": "q-basic-types",
      "navLabel": "基础类型",
      "question": "TypeScript 中常见的基础类型有哪些？",
      "questionNote": "先掌握变量、数组与简单对象的类型标注，再学习进阶语法。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "最常用的是 "
          },
          {
            "type": "code",
            "value": "string"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "number"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "boolean"
          },
          {
            "type": "text",
            "value": "，以及数组与对象形状。"
          }
        ],
        [
          {
            "type": "code",
            "value": "let name: string = \"Tom\""
          },
          {
            "type": "text",
            "value": "；"
          },
          {
            "type": "code",
            "value": "let ids: number[] = [1, 2]"
          },
          {
            "type": "text",
            "value": " 或 "
          },
          {
            "type": "code",
            "value": "Array<number>"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "对象写法："
          },
          {
            "type": "code",
            "value": "type User = { id: string; age: number }"
          },
          {
            "type": "text",
            "value": "。类型标注正确时，属性访问有提示，拼写错误会在编译期报错。"
          }
        ]
      ]
    },
    {
      "id": "q-type-interface",
      "navLabel": "type 和 interface",
      "question": "type 与 interface 应如何选择？",
      "questionNote": "掌握一条选型规则即可，无需深究二者性能差异。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "描述对象形状时，"
          },
          {
            "type": "code",
            "value": "type"
          },
          {
            "type": "text",
            "value": " 与 "
          },
          {
            "type": "code",
            "value": "interface"
          },
          {
            "type": "text",
            "value": " 大多可互换；需要联合类型（"
          },
          {
            "type": "code",
            "value": "|"
          },
          {
            "type": "text",
            "value": "）时 "
          },
          {
            "type": "code",
            "value": "type"
          },
          {
            "type": "text",
            "value": " 更直接。"
          }
        ],
        [
          {
            "type": "code",
            "value": "interface User { id: string; name: string }"
          },
          {
            "type": "text",
            "value": " 与 "
          },
          {
            "type": "code",
            "value": "type User = { id: string; name: string }"
          },
          {
            "type": "text",
            "value": " 效果接近，团队选定一种风格并保持一致即可。"
          }
        ],
        [
          {
            "type": "code",
            "value": "type Id = string | number"
          },
          {
            "type": "text",
            "value": " 这类「A 或 B」的写法，"
          },
          {
            "type": "code",
            "value": "interface"
          },
          {
            "type": "text",
            "value": " 不便直接表达，应使用 "
          },
          {
            "type": "code",
            "value": "type"
          },
          {
            "type": "text",
            "value": "。"
          }
        ]
      ]
    },
    {
      "id": "q-any-unknown",
      "navLabel": "any 和 unknown",
      "question": "any 与 unknown 有何区别？",
      "questionNote": "记住 unknown 比 any 更安全，是处理外部数据的首选。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": " 几乎放弃类型检查，"
          },
          {
            "type": "code",
            "value": "unknown"
          },
          {
            "type": "text",
            "value": " 表示类型尚不确定，使用前必须先判断或收窄。"
          }
        ],
        [
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": "：可写 "
          },
          {
            "type": "code",
            "value": "(x as any).foo()"
          },
          {
            "type": "text",
            "value": "，编译器放行，运行时才可能报错。适合临时过渡，应尽快改为具体类型。"
          }
        ],
        [
          {
            "type": "code",
            "value": "unknown"
          },
          {
            "type": "text",
            "value": "：不能直接访问属性，需先 "
          },
          {
            "type": "code",
            "value": "typeof x === \"string\""
          },
          {
            "type": "text",
            "value": " 等判断后再用。处理 "
          },
          {
            "type": "code",
            "value": "fetch().json()"
          },
          {
            "type": "text",
            "value": " 等外部数据时，优先使用 "
          },
          {
            "type": "code",
            "value": "unknown"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "unknown 必须先收窄才能使用。"
          }
        ],
        [
          {
            "type": "code",
            "value": "function f(x: unknown) {\n  // x.toFixed() // 报错\n  if (typeof x === 'number') x.toFixed(2) // OK\n}\n// any：可随意调用，但放弃类型保护"
          }
        ]
      ]
    },
    {
      "id": "q-optional-union",
      "navLabel": "可选与联合",
      "question": "可选属性（?）与联合类型（|）分别如何运用？",
      "questionNote": "表单字段与接口返回值中，这两类写法最为常见。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "code",
            "value": "?"
          },
          {
            "type": "text",
            "value": " 表示字段可有可无，"
          },
          {
            "type": "code",
            "value": "|"
          },
          {
            "type": "text",
            "value": " 表示值可能是若干类型之一。"
          }
        ],
        [
          {
            "type": "text",
            "value": "可选属性："
          },
          {
            "type": "code",
            "value": "type User = { id: string; nickname?: string }"
          },
          {
            "type": "text",
            "value": "，"
          },
          {
            "type": "code",
            "value": "nickname"
          },
          {
            "type": "text",
            "value": " 可传可不传；访问时常配合 "
          },
          {
            "type": "code",
            "value": "?."
          },
          {
            "type": "text",
            "value": " 可选链。"
          }
        ],
        [
          {
            "type": "text",
            "value": "联合类型："
          },
          {
            "type": "code",
            "value": "type Status = \"pending\" | \"done\" | \"failed\""
          },
          {
            "type": "text",
            "value": "，变量只能是列出的字面量之一；"
          },
          {
            "type": "code",
            "value": "string | null"
          },
          {
            "type": "text",
            "value": " 则用于表示可能为空。"
          }
        ]
      ]
    },
    {
      "id": "q-type-narrowing",
      "navLabel": "类型收窄",
      "question": "TypeScript 中常见的类型收窄写法有哪些？",
      "questionNote": "类型收窄指在分支中将宽类型缩小为更具体的类型。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "在 "
          },
          {
            "type": "code",
            "value": "if"
          },
          {
            "type": "text",
            "value": " 分支中做判断后，TypeScript 会自动收窄类型，此后访问属性才安全。"
          }
        ],
        [
          {
            "type": "text",
            "value": "1）"
          },
          {
            "type": "code",
            "value": "typeof"
          },
          {
            "type": "text",
            "value": "："
          },
          {
            "type": "code",
            "value": "if (typeof x === \"string\") { x.toUpperCase() }"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "2）"
          },
          {
            "type": "code",
            "value": "in"
          },
          {
            "type": "text",
            "value": "："
          },
          {
            "type": "code",
            "value": "if (\"name\" in obj)"
          },
          {
            "type": "text",
            "value": " 可区分不同对象形态；联合类型也可通过 "
          },
          {
            "type": "code",
            "value": "switch (x.status)"
          },
          {
            "type": "text",
            "value": " 逐分支收窄。"
          }
        ]
      ]
    },
    {
      "id": "q-generics",
      "navLabel": "泛型",
      "question": "请说明泛型的作用，并举例说明典型用法。",
      "questionNote": "理解「类型占位符，使输入与输出类型保持一致」即可。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "泛型是类型占位符，使函数或组件在复用时仍保留具体类型，避免退化为 "
          },
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "code",
            "value": "function last<T>(arr: T[]): T | undefined"
          },
          {
            "type": "text",
            "value": "，调用 "
          },
          {
            "type": "code",
            "value": "last([1, 2])"
          },
          {
            "type": "text",
            "value": " 时 "
          },
          {
            "type": "code",
            "value": "T"
          },
          {
            "type": "text",
            "value": " 推断为 "
          },
          {
            "type": "code",
            "value": "number"
          },
          {
            "type": "text",
            "value": "，返回 "
          },
          {
            "type": "code",
            "value": "number | undefined"
          },
          {
            "type": "text",
            "value": "，而非 "
          },
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "组件中为 "
          },
          {
            "type": "code",
            "value": "props"
          },
          {
            "type": "text",
            "value": " 声明泛型同理：列表项类型与 "
          },
          {
            "type": "code",
            "value": "onChange"
          },
          {
            "type": "text",
            "value": " 回调参数类型保持一致。"
          }
        ]
      ]
    },
    {
      "id": "q-utility",
      "navLabel": "工具类型",
      "question": "Partial 与 Pick 工具类型各解决什么问题？",
      "questionNote": "内置工具类型在编译期变换已有类型，业务中应用广泛。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "在已有类型上派生新类型，无需手写第二份重复定义。"
          }
        ],
        [
          {
            "type": "code",
            "value": "Partial<User>"
          },
          {
            "type": "text",
            "value": "：所有字段变为可选，适用于表单草稿、局部更新接口入参。"
          }
        ],
        [
          {
            "type": "code",
            "value": "Pick<User, \"id\" | \"name\">"
          },
          {
            "type": "text",
            "value": "：仅保留指定字段，适用于列表页展示部分列、下拉选项等场景。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "Partial / Pick 作用在同一类型。"
          }
        ],
        [
          {
            "type": "code",
            "value": "type User = { id: number; name: string; age: number }\ntype UserPatch = Partial<User>           // 字段全可选\ntype UserLite = Pick<User, 'id' | 'name'> // 只保留两字段"
          }
        ]
      ]
    },
    {
      "id": "q-strict-config",
      "navLabel": "tsconfig strict",
      "question": "开启 tsconfig strict 后，常见编译报错有哪些？",
      "questionNote": "strict 是一组子开关的合集，先熟悉最常见的两项即可。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "code",
            "value": "strict"
          },
          {
            "type": "text",
            "value": " 开启后，以往在 JavaScript 中「能运行」的写法会在编译期被拦截。"
          }
        ],
        [
          {
            "type": "code",
            "value": "strictNullChecks"
          },
          {
            "type": "text",
            "value": "："
          },
          {
            "type": "code",
            "value": "null"
          },
          {
            "type": "text",
            "value": " / "
          },
          {
            "type": "code",
            "value": "undefined"
          },
          {
            "type": "text",
            "value": " 不能赋给 "
          },
          {
            "type": "code",
            "value": "string"
          },
          {
            "type": "text",
            "value": " 等类型，需用 "
          },
          {
            "type": "code",
            "value": "string | null"
          },
          {
            "type": "text",
            "value": " 或可选链 "
          },
          {
            "type": "code",
            "value": "?."
          },
          {
            "type": "text",
            "value": " 处理。"
          }
        ],
        [
          {
            "type": "code",
            "value": "noImplicitAny"
          },
          {
            "type": "text",
            "value": "：函数参数、变量推断不出类型时会报隐式 "
          },
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": "，需补充类型注解。可按目录逐步开启 "
          },
          {
            "type": "code",
            "value": "strict"
          },
          {
            "type": "text",
            "value": "，无需一次改完全仓。"
          }
        ]
      ]
    },
