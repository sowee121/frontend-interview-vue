        [
          {
            "type": "text",
            "value": "泛型约束："
          },
          {
            "type": "code",
            "value": "<T extends { id: string }>"
          },
          {
            "type": "text",
            "value": " 保证 T 至少有 "
          },
          {
            "type": "code",
            "value": "id"
          },
          {
            "type": "text",
            "value": "，避免在函数体里访问属性时报错。"
          }
        ]
      ]
    },
