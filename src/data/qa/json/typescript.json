          },
          {
            "type": "code",
            "value": "1"
          },
          {
            "type": "text",
            "value": " 而不是宽化为 "
          },
          {
            "type": "code",
            "value": "number"
          },
          {
            "type": "text",
            "value": "；若写成 "
          },
          {
            "type": "code",
            "value": "const cfg: Record<string, number> = { a: 1 }"
          },
          {
            "type": "text",
            "value": " 则推断变宽。"
          }
        ],
        [
          {
            "type": "text",
            "value": "适合配置表、路由表、主题 token：既要约束 shape，又要后面 "
