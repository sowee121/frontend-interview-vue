  "items": [
    {
      "id": "q-why",
      "navLabel": "为啥用 TS",
      "question": "项目里为啥要上 TypeScript？",
      "questionNote": "说清「编译期检查 + 编辑器补全」两大收益即可。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "text",
            "value": "TypeScript 是 JavaScript 的超集，编译前帮你检查类型，改字段时能一次性找出引用处，编辑器补全和跳转也更准。"
          }
        ],
        [
          {
            "type": "text",
            "value": "1）"
          },
          {
            "type": "strong",
            "value": "少写错"
          },
          {
            "type": "text",
            "value": "：接口字段从 "
          },
          {
            "type": "code",
            "value": "name"
          },
          {
            "type": "text",
            "value": " 改成 "
          },
          {
            "type": "code",
            "value": "username"
          },
          {
            "type": "text",
            "value": "，类型一改，引用处编译报错，比运行才发现省很多。"
          }
        ],
        [
          {
            "type": "text",
            "value": "2）"
          },
          {
            "type": "strong",
            "value": "代价"
          },
          {
            "type": "text",
            "value": "：多写类型声明；个别第三方库缺类型要补 "
          },
          {
            "type": "code",
            "value": ".d.ts"
          },
          {
            "type": "text",
            "value": "。整体利大于弊。"
          }
        ]
      ]
    },
    {
      "id": "q-basic-types",
      "navLabel": "基础类型",
      "question": "TypeScript 里常见基础类型有哪些？",
      "questionNote": "先会写变量、数组、简单对象，再谈进阶语法。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "text",
            "value": "最常用的是 "
          },
          {
            "type": "code",
            "value": "string"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "number"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "boolean"
          },
          {
            "type": "text",
            "value": "，以及数组和对象形状。"
          }
        ],
        [
          {
            "type": "code",
            "value": "let name: string = \"Tom\""
          },
          {
            "type": "text",
            "value": "；"
          },
          {
            "type": "code",
            "value": "let ids: number[] = [1, 2]"
          },
          {
            "type": "text",
            "value": " 或 "
          },
          {
            "type": "code",
            "value": "Array<number>"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "对象写法："
          },
          {
            "type": "code",
            "value": "type User = { id: string; age: number }"
          },
          {
            "type": "text",
            "value": "。类型写对，点属性时编辑器会提示，拼错字段编译也会报错。"
          }
        ]
      ]
    },
    {
      "id": "q-type-interface",
      "navLabel": "type 和 interface",
      "question": "type 和 interface 怎么选？",
      "questionNote": "记一条简单规则就够，不必背性能差异。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "text",
            "value": "描述对象形状，"
          },
          {
            "type": "code",
            "value": "type"
          },
          {
            "type": "text",
            "value": " 和 "
          },
          {
            "type": "code",
            "value": "interface"
          },
          {
            "type": "text",
            "value": " 大多可以互换；要写联合类型（"
          },
          {
            "type": "code",
            "value": "|"
          },
          {
            "type": "text",
            "value": "）时用 "
          },
          {
            "type": "code",
            "value": "type"
          },
          {
            "type": "text",
            "value": " 更方便。"
          }
        ],
        [
          {
            "type": "code",
            "value": "interface User { id: string; name: string }"
          },
          {
            "type": "text",
            "value": " 和 "
          },
          {
            "type": "code",
            "value": "type User = { id: string; name: string }"
          },
          {
            "type": "text",
            "value": " 效果接近，团队选一种风格统一即可。"
          }
        ],
        [
          {
            "type": "code",
            "value": "type Id = string | number"
          },
          {
            "type": "text",
            "value": " 这种「可能是 A 或 B」的写法，"
          },
          {
            "type": "code",
            "value": "interface"
          },
          {
            "type": "text",
            "value": " 不好直接表达，用 "
          },
          {
            "type": "code",
            "value": "type"
          },
          {
            "type": "text",
            "value": "。"
          }
        ]
      ]
    },
    {
      "id": "q-any-unknown",
      "navLabel": "any 和 unknown",
      "question": "any 和 unknown 区别？",
      "questionNote": "先记住：unknown 比 any 更安全。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": " 几乎不检查，"
          },
          {
            "type": "code",
            "value": "unknown"
          },
          {
            "type": "text",
            "value": " 表示「类型还不确定」，使用前必须先判断或收窄。"
          }
        ],
        [
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": "：你能写 "
          },
          {
            "type": "code",
            "value": "(x as any).foo()"
          },
          {
            "type": "text",
            "value": "，编译器放行，运行时才可能报错。适合临时过渡，应尽快改成具体类型。"
          }
        ],
        [
          {
            "type": "code",
            "value": "unknown"
          },
          {
            "type": "text",
            "value": "：不能直接访问属性，要先 "
          },
          {
            "type": "code",
            "value": "typeof x === \"string\""
          },
          {
            "type": "text",
            "value": " 等判断后再用。接 "
          },
          {
            "type": "code",
            "value": "fetch().json()"
          },
          {
            "type": "text",
            "value": " 等外部数据，优先用 "
          },
          {
            "type": "code",
            "value": "unknown"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "unknown 必须先收窄才能用。"
          }
        ],
        [
          {
            "type": "code",
            "value": "function f(x: unknown) {\n  // x.toFixed() // 报错\n  if (typeof x === 'number') x.toFixed(2) // OK\n}\n// any：可随意调用，但放弃类型保护"
          }
        ]
      ]
    },
    {
      "id": "q-optional-union",
      "navLabel": "可选与联合",
      "question": "可选属性（?）和联合类型（|）怎么用？",
      "questionNote": "表单、接口返回值里这两类写法最常见。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "code",
            "value": "?"
          },
          {
            "type": "text",
            "value": " 表示字段可有可无，"
          },
          {
            "type": "code",
            "value": "|"
          },
          {
            "type": "text",
            "value": " 表示值可能是几种类型之一。"
          }
        ],
        [
          {
            "type": "text",
            "value": "可选属性："
          },
          {
            "type": "code",
            "value": "type User = { id: string; nickname?: string }"
          },
          {
            "type": "text",
            "value": "，"
          },
          {
            "type": "code",
            "value": "nickname"
          },
          {
            "type": "text",
            "value": " 可传可不传；访问前常用 "
          },
          {
            "type": "code",
            "value": "?."
          },
          {
            "type": "text",
            "value": " 可选链。"
          }
        ],
        [
          {
            "type": "text",
            "value": "联合类型："
          },
          {
            "type": "code",
            "value": "type Status = \"pending\" | \"done\" | \"failed\""
          },
          {
            "type": "text",
            "value": "，变量只能是列出的字面量之一；也常见 "
          },
          {
            "type": "code",
            "value": "string | null"
          },
          {
            "type": "text",
            "value": " 表示可能有空值。"
          }
        ]
      ]
    },
    {
      "id": "q-type-narrowing",
      "navLabel": "类型收窄",
      "question": "TypeScript 类型收窄常见写法有哪些？",
      "questionNote": "类型收窄 = 在分支里把宽类型缩成更具体的类型。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "text",
            "value": "在 "
          },
          {
            "type": "code",
            "value": "if"
          },
          {
            "type": "text",
            "value": " 分支里做判断，TypeScript 会自动把类型收窄，之后访问属性才安全。"
          }
        ],
        [
          {
            "type": "text",
            "value": "1）"
          },
          {
            "type": "code",
            "value": "typeof"
          },
          {
            "type": "text",
            "value": "："
          },
          {
            "type": "code",
            "value": "if (typeof x === \"string\") { x.toUpperCase() }"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "2）"
          },
          {
            "type": "code",
            "value": "in"
          },
          {
            "type": "text",
            "value": "："
          },
          {
            "type": "code",
            "value": "if (\"name\" in obj)"
          },
          {
            "type": "text",
            "value": " 区分不同对象形态；联合类型靠 "
          },
          {
            "type": "code",
            "value": "switch (x.status)"
          },
          {
            "type": "text",
            "value": " 也能逐分支收窄。"
          }
        ]
      ]
    },
    {
      "id": "q-generics",
      "navLabel": "泛型",
      "question": "泛型是干啥的？举个栗子",
      "questionNote": "理解「类型占位符，输入输出类型绑在一起」即可。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "text",
            "value": "泛型是类型占位符，让函数或组件在复用时仍保留具体类型，避免退化成 "
          },
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "code",
            "value": "function last<T>(arr: T[]): T | undefined"
          },
          {
            "type": "text",
            "value": "，调用 "
          },
          {
            "type": "code",
            "value": "last([1, 2])"
          },
          {
            "type": "text",
            "value": " 时 "
          },
          {
            "type": "code",
            "value": "T"
          },
          {
            "type": "text",
            "value": " 推断为 "
          },
          {
            "type": "code",
            "value": "number"
          },
          {
            "type": "text",
            "value": "，返回值是 "
          },
          {
            "type": "code",
            "value": "number | undefined"
          },
          {
            "type": "text",
            "value": "，而不是 "
          },
          {
            "type": "code",
            "value": "any"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "组件里给 "
          },
          {
            "type": "code",
            "value": "props"
          },
          {
            "type": "text",
            "value": " 传泛型也是同理：列表项类型和 "
          },
          {
            "type": "code",
            "value": "onChange"
          },
          {
            "type": "text",
            "value": " 回调参数类型保持一致。"
          }
        ]
      ]
    },
    {
      "id": "q-utility",
      "navLabel": "工具类型",
      "question": "Partial 和 Pick 是干啥的？",
      "questionNote": "内置工具类型在编译期变换已有类型，业务里很常用。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "text",
            "value": "在已有类型上「改一改」得到新类型，不用手写第二份重复定义。"
          }
        ],
        [
          {
            "type": "code",
            "value": "Partial<User>"
          },
          {
            "type": "text",
            "value": "：所有字段变可选，适合表单草稿、局部更新接口入参。"
          }
        ],
        [
          {
            "type": "code",
            "value": "Pick<User, \"id\" | \"name\">"
          },
          {
            "type": "text",
            "value": "：只保留指定字段，适合列表页只展示部分列、下拉选项只要 id 和名称。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "Partial / Pick 作用在同一类型。"
          }
        ],
        [
          {
            "type": "code",
            "value": "type User = { id: number; name: string; age: number }\ntype UserPatch = Partial<User>           // 字段全可选\ntype UserLite = Pick<User, 'id' | 'name'> // 只保留两字段"
          }
        ]
      ]
    },
    {
      "id": "q-enum",
      "navLabel": "枚举写法",
      "question": "TS 里 enum 推荐用吗？",
      "questionNote": "很多团队更常用 as const 对象，运行时零开销。",
      "answer": [
        [
          {
            "type": "strong",
            "value": "一句话："
          },
          {
            "type": "text",
            "value": "能用 "
          },
          {
            "type": "code",
            "value": "as const"
          },
          {
            "type": "text",
            "value": " 对象 + 类型别名替代 "
          },
          {
            "type": "code",
            "value": "enum"
          },
          {
            "type": "text",
            "value": " 时，优先前者；与后端生成代码自带 enum 则按项目约定走。"
          }
        ],
        [
          {
            "type": "code",
            "value": "const Status = { Pending: \"pending\", Done: \"done\" } as const"
          },
          {
            "type": "text",
            "value": "，"
          },
          {
            "type": "code",
            "value": "type Status = typeof Status[keyof typeof Status]"
          },
          {
            "type": "text",
            "value": "，值和类型同源，编译后就是普通对象。"
          }
        ],
        [
          {
            "type": "code",
            "value": "as const"
          },
          {
            "type": "text",
            "value": " 还会把字面量收窄，例如 "
          },
          {
            "type": "code",
            "value": "[1, 2] as const"
          },
          {
            "type": "text",
            "value": " 推断为 "
          },
          {
            "type": "code",
            "value": "readonly [1, 2]"
          },
          {
            "type": "text",
            "value": "，而不是宽化的 "
          },
          {
            "type": "code",
            "value": "number[]"
          },
          {
            "type": "text",
            "value": "。"
          }
        ]
      ]
    },
    {
