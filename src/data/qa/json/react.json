          },
          {
            "type": "strong",
            "value": "不要用 index 当 key"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "同一 index 在 diff 里可能对应不同实体，子组件 "
          },
          {
            "type": "code",
            "value": "useState"
          },
          {
            "type": "text",
            "value": " 会复用错节点，出现输入框内容乱跑、动画错位。"
          }
        ],
        [
          {
            "type": "text",
            "value": "优先用稳定主键：数据库 "
          },
          {
            "type": "code",
            "value": "id"
          },
          {
            "type": "text",
            "value": "、业务 "
          },
          {
            "type": "code",
            "value": "orderNo"
          },
          {
            "type": "text",
            "value": " 等。"
          }
        ],
        [
          {
            "type": "code",
            "value": "key={Math.random()}"
          },
          {
            "type": "text",
            "value": " 每次渲染都变，等于禁用复用，性能更差，比 index 还糟。"
          }
        ]
      ]
