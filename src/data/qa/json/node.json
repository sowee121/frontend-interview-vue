          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "通过 "
          },
          {
            "type": "code",
            "value": "process.env.XXX"
          },
          {
            "type": "text",
            "value": " 读取配置；本地使用 "
          },
          {
            "type": "code",
            "value": ".env"
          },
          {
            "type": "text",
            "value": "，生产由运维或 CI 注入。"
          }
        ],
        [
          {
            "type": "text",
