          }
        ],
        [
          {
            "type": "code",
            "value": "function debounce(fn, wait) {\n  let t\n  return function (...args) {\n    clearTimeout(t)\n    t = setTimeout(() => fn.apply(this, args), wait)\n  }\n}\n// 搜索：onInput={debounce(fetchList, 300)}"
