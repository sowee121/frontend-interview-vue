          },
          {
            "type": "code",
            "value": "finally"
          },
          {
            "type": "text",
            "value": " 不改变链上值，只做收尾。面试能把“返回新 Promise + 返回值/异常如何影响状态”讲清即可。"
          }
        ]
      ]
