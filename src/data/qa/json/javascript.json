          },
          {
            "type": "text",
            "value": " 减少无效请求；"
          },
          {
            "type": "code",
            "value": "resize"
          },
          {
            "type": "text",
            "value": " 结束后再量布局。leading 选项可在首次立即触发。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "节流（throttle）："
