          {
            "type": "code",
            "value": "Promise.then/catch/finally"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "queueMicrotask"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "MutationObserver"
          },
          {
            "type": "text",
            "value": " 等；执行过程中新入队的微任务会在本轮继续清完。"
          }
        ],
        [
          {
            "type": "text",
            "value": "宏任务包括整段 script、"
          },
          {
            "type": "code",
            "value": "setTimeout"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "setInterval"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "I/O"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "message"
          },
          {
            "type": "text",
            "value": " 等。因此 "
          },
          {
            "type": "code",
            "value": "Promise"
          },
          {
            "type": "text",
            "value": " 回调常早于 "
