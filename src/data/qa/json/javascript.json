          }
        ],
        [
          {
            "type": "text",
            "value": "场景：滚动吸顶、拖拽跟随、按钮防重复点击；与渲染帧对齐可用 "
          },
          {
            "type": "code",
            "value": "requestAnimationFrame"
          },
          {
            "type": "text",
            "value": " 做 rAF 节流。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "防抖骨架（完整版见编程题章）。"
          }
        ],
        [
          {
            "type": "code",
            "value": "function debounce(fn, wait) {\n  let t\n  return function (...args) {\n    clearTimeout(t)\n    t = setTimeout(() => fn.apply(this, args), wait)\n  }\n}\n// 搜索：onInput={debounce(fetchList, 300)}"
          }
        ]
      ]
