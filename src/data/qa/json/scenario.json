            "type": "text",
            "value": " 请求，结果 append 到列表。"
          }
        ],
        [
          {
            "type": "text",
            "value": "2）飞行中设 "
          },
          {
            "type": "code",
            "value": "loading"
          },
          {
            "type": "text",
            "value": " 防重复；"
          },
          {
            "type": "code",
            "value": "hasMore === false"
          },
          {
            "type": "text",
            "value": " 时 disconnect；失败给重试。"
