        [
          { "type": "text", "value": "2）" },
          { "type": "strong", "value": "取消上一次" },
          { "type": "text", "value": "：每次带新 " },
          { "type": "code", "value": "AbortController" },
          { "type": "text", "value": "，下次输入 " },
          { "type": "code", "value": "abort()" },
          { "type": "text", "value": "，避免慢请求覆盖新关键词结果。" }
