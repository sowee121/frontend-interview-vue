        [
          {
            "type": "text",
            "value": "2）"
          },
          {
            "type": "code",
            "value": "fetch"
          },
          {
            "type": "text",
            "value": " 可封装带 memo 的 "
          },
          {
            "type": "code",
            "value": "getAccessToken()"
          },
          {
            "type": "text",
            "value": " 共享刷新逻辑。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "refresh 单飞。"
          }
        ],
        [
          {
            "type": "code",
            "value": "let refreshing = null\nasync function ensureToken() {\n  if (!refreshing) {\n    refreshing = refreshApi().finally(() => { refreshing = null })\n  }\n  return refreshing\n}"
          }
        ]
      ]
    },
