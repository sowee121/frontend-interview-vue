        [
          { "type": "text", "value": "3）封装层统一处理 " },
          { "type": "code", "value": "401" },
          { "type": "text", "value": "：只让一个 refresh 在飞，其它进队列，成功重放、失败跳登录；路由 " },
          { "type": "code", "value": "beforeEach" },
          { "type": "text", "value": " 拦未登录页。" }
        ]
      ]
    },
