          {
            "type": "text",
            "value": "App 管理全局前后台；Page 管理页面入栈与展示；Component 管理组件挂载与卸载，层次划分与 Vue 类似。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "App："
          },
          {
            "type": "code",
            "value": "onLaunch"
          },
          {
            "type": "text",
            "value": "（冷启动）、"
          },
          {
            "type": "code",
            "value": "onShow"
          },
          {
            "type": "text",
            "value": " / "
          },
          {
            "type": "code",
            "value": "onHide"
          },
          {
            "type": "text",
            "value": "（前后台切换）。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "Page："
          },
          {
            "type": "code",
            "value": "onLoad"
          },
          {
            "type": "text",
            "value": "（入参 options）、"
          },
          {
            "type": "code",
            "value": "onShow"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "onReady"
          },
          {
            "type": "text",
            "value": "（首屏渲染完成）、"
          },
          {
            "type": "code",
            "value": "onHide"
          },
          {
            "type": "text",
            "value": "、"
          },
          {
            "type": "code",
            "value": "onUnload"
          },
          {
            "type": "text",
            "value": "（页面出栈销毁）。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "Component："
          },
          {
            "type": "code",
            "value": "attached"
          },
          {
            "type": "text",
            "value": " / "
          },
          {
            "type": "code",
            "value": "ready"
          },
          {
            "type": "text",
            "value": " / "
          },
          {
            "type": "code",
            "value": "detached"
          },
          {
            "type": "text",
            "value": "，对应挂载、就绪与卸载阶段。"
          }
        ],
        [
          {
            "type": "text",
            "value": "实践建议：页面每次可见时在 "
          },
          {
            "type": "code",
            "value": "onShow"
          },
          {
            "type": "text",
            "value": " 拉取数据；在 "
          },
          {
            "type": "code",
            "value": "onLoad"
          },
          {
            "type": "text",
            "value": " 读取路由参数；"
          },
          {
            "type": "code",
            "value": "onUnload"
          },
          {
            "type": "text",
            "value": " 清理定时器与订阅。"
          }
        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "Page 常用钩子骨架。"
          }
        ],
        [
          {
            "type": "code",
            "value": "Page({\n  onLoad(query) { /* 读参、首拉 */ },\n  onShow() { /* 每次可见 */ },\n  onHide() { /* 切入后台 */ },\n  onUnload() { /* 卸载清理 */ },\n})"
          }
        ]
      ]
    },
