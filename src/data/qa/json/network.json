        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "浏览器侧连接。"
          }
        ],
        [
          {
            "type": "code",
            "value": "const ws = new WebSocket('wss://example.com/ws')\nws.onopen = () => ws.send('hi')\nws.onmessage = (e) => console.log(e.data)"
          }
        ]
      ]
    },
