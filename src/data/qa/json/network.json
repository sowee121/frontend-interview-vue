    {
      "id": "q-tcp-handshake",
      "navLabel": "TCP 三次握手",
      "question": "TCP 三次握手在干啥？",
      "answer": [
        [
          {
            "type": "text",
            "value": "1）客户端发 "
          },
          {
            "type": "code",
            "value": "SYN"
          },
          {
            "type": "text",
            "value": "，带初始序号；2）服务端 "
          },
          {
            "type": "code",
            "value": "SYN-ACK"
          },
          {
            "type": "text",
            "value": " 确认并带上自己的序号；3）客户端 "
          },
          {
            "type": "code",
            "value": "ACK"
          },
          {
            "type": "text",
            "value": "，双方确认对方收发能力，进入 "
          },
          {
            "type": "code",
            "value": "ESTABLISHED"
          },
          {
            "type": "text",
            "value": "。"
          }
        ],
        [
          {
            "type": "text",
            "value": "为啥不是两次：防止历史滞留连接的请求被服务端误当成新连接；三次让双方同步初始序列号。前端面试点到为止，深挖交给后端。"
          }
        ]
      ]
    },
