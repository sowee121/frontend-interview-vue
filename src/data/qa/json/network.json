            "type": "strong",
            "value": "TLS"
          },
          {
            "type": "text",
            "value": "：握手阶段用非对称加密交换或协商出 "
          },
          {
            "type": "strong",
            "value": "对称会话密钥"
          },
          {
            "type": "text",
            "value": "，之后数据对称加密传输；"
          },
          {
            "type": "strong",
            "value": "证书链"
          },
          {
            "type": "text",
            "value": "由客户端校验（域名、有效期、是否被吊销），防中间人冒充。"
          }
        ],
        [
          {
            "type": "text",
            "value": "顺带提 "
          },
          {
            "type": "code",
            "value": "HSTS"
          },
          {
            "type": "text",
            "value": " 强制走 HTTPS、"
          },
          {
            "type": "code",
            "value": "HPKP"
          },
          {
            "type": "text",
            "value": " 已废弃别乱背。"
          }
        ]
      ]
    },
