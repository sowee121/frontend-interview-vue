          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "箭头函数不绑定自己的 this。"
          }
        ],
        [
          {
            "type": "code",
            "value": "const obj = {\n  n: 1,\n  // 错：箭头拿不到 obj 当 this\n  bad: () => this.n,\n  // 对：普通方法\n  ok() { return this.n },\n  // 默认参数\n  add(x, y = 1) { return x + y },\n}"
          }
        ]
      ]
