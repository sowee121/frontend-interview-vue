        ],
        [
          {
            "type": "text",
            "value": "典型：DOM 节点挂扩展数据、第三方实例缓存；Vue 3 用 WeakMap 关联 "
          },
          {
            "type": "code",
            "value": "reactive"
          },
          {
            "type": "text",
            "value": " 代理与原始对象，避免内存泄漏。"
          }
        ]
      ]
    },
