        [
          {
            "type": "text",
            "value": "3）"
          },
          {
            "type": "strong",
            "value": "同步"
          },
          {
            "type": "text",
            "value": "：原生登出通知 H5 清本地态；续期由原生统一刷新后再注入。"
          }
        ]
      ]
