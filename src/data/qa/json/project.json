        [
          {
            "type": "text",
            "value": "1）"
          },
          {
            "type": "strong",
            "value": "H5 → 小程序"
          },
          {
            "type": "text",
            "value": "：调用 "
          },
          {
            "type": "code",
            "value": "wx.miniProgram"
          },
          {
            "type": "text",
            "value": " 的跳转等 API；回传数据用 "
          },
          {
            "type": "code",
            "value": "postMessage"
          },
          {
            "type": "text",
            "value": "，小程序在 "
          },
          {
            "type": "code",
            "value": "bindmessage"
          },
          {
            "type": "text",
            "value": " 里接收。"
          }
        ],
        [
          {
            "type": "text",
            "value": "2）"
          },
          {
            "type": "strong",
            "value": "H5 → App"
          },
          {
            "type": "text",
            "value": "：原生向页面注入 Bridge；H5 调用其中方法，原生处理完再回调页面。"
          }
        ],
        [
          {
            "type": "text",
            "value": "3）"
          },
          {
            "type": "strong",
            "value": "小程序 → H5"
          },
          {
            "type": "text",
            "value": "：不能直接执行页面函数，通常改 web-view 的 URL 参数；H5 读参后执行逻辑。"
          }
        ],
        [
          {
            "type": "text",
            "value": "4）"
          },
          {
            "type": "strong",
            "value": "App → H5"
          },
          {
            "type": "text",
            "value": "：H5 先在 window 注册回调；原生用 "
          },
          {
            "type": "code",
            "value": "evaluateJavascript"
          },
          {
            "type": "text",
            "value": " 触发回调，把数据传给页面。"
          }
        ],
        [
          {
            "type": "text",
            "value": "5）"
          },
          {
            "type": "strong",
            "value": "封装"
          },
          {
            "type": "text",
            "value": "：对外统一 "
          },
          {
            "type": "code",
            "value": "call(method, params)"
          },
          {
            "type": "text",
            "value": "，内部按环境分发，并处理超时与能力检测。"
          }
        ]
