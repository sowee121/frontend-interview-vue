      "answer": [
        [
          {
            "type": "strong",
            "value": "要点："
          },
          {
            "type": "text",
            "value": "须确认是否真正解决问题、scope 是否悄然扩大，以及错误与空状态处理。"
          }
        ],
        [
          {
            "type": "text",
            "value": "1）正确性：类型、异步、竞态；跑测试。"
          }
        ],
        [
          {
            "type": "text",
            "value": "2）安全：XSS、密钥、权限只藏 UI。"
          }
        ],
        [
          {
            "type": "text",
            "value": "3）可维护：是否多余抽象、是否符合项目模式。"
          }
        ]
      ]
    },
