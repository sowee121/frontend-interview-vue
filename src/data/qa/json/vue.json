        ],
        [
          {
            "type": "strong",
            "value": "示例："
          },
          {
            "type": "text",
            "value": "缓存进出钩子。"
          }
        ],
        [
          {
            "type": "code",
            "value": "<keep-alive :include=\"['List']\">\n  <router-view />\n</keep-alive>\n// 组件内\nactivated() { /* 恢复轮询 */ }\ndeactivated() { /* 暂停定时器 */ }"
          }
        ]
      ]
