        [
          {
            "type": "code",
            "value": "v-if"
          },
          {
            "type": "text",
            "value": " 与 "
          },
          {
            "type": "code",
            "value": "v-for"
          },
          {
            "type": "text",
            "value": " 不要同元素并用（优先级易混），用外层 "
